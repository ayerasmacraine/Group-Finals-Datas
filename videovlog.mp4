5,\"addParticipantIdToGroupThread\",[19,\"1379820553630715\"],[19,\"100083820717784\"],[19,\"1778677567719\"],[19,\"1778677779648\"],[19,\"1778595129962\"],[9],false,\"Added by Kristine Ancheta\",[19,\"0\"],[19,\"80\"],[9],[19,\"0\"],false,false,[19,\"0\"]]],[1,[5,\"addParticipantIdToGroupThread\",[19,\"1379820553630715\"],[19,\"100088787396652\"],[19,\"1774576572977\"],[19,\"1774576583304\"],[19,\"1778595129962\"],[9],false,\"Added by Aj Iscat\",[19,\"0\"],[19,\"80\"],[9],[19,\"0\"],false,false,[19,\"0\"]]],[1,[5,\"clearPinnedMessages\",[19,\"1379820553630715\"]]],[1,[5,\"setPinnedMessage\",[19,\"1379820553630715\"],\"mid.$gAATm8IHz8_uh1CPrL2bot6hxseQ2\",[19,\"1767964176507\"],[19,\"1\"]]],[1,[5,\"deleteThenInsertMessage\",\"\\ud83d\\udcccTake note:\\n\\n\\u2705Sa CWTS *twice* lang pwede *malate*, yung *pangatlo* equivalent to *1 absent*\\n\\n\\u2705 *Twice* lang pwede *mag-absent or pa-excuse*, yung *pangatlo* equivalent to *FA*, FA means *FAILURE due to Absences*\\n\\n\\u2705Kapag *magpapa-excuse make sure na magpass ng excuse letter*, kayo mismo ang magpapass, hindi ipapakisuyo kung kanikanino, and kung magpapaexcuse dapat before ng meeting magsend na sakin ng PM with excuse letter signed by parent or guardian and dapat nakapicture na hawak ng parent or guardian para sure na aware sila na hindi kayo makakapasok at magpapaalam lang kayo hanggang before ng pasok natin, 8am every saturday ang pasok kaya dapat *7:59 nakapagsend na kayo ng excuse letter unless emergency.*\\n\\n\\n\\u2705Hindi porke nagpaexcuse okay na yun, hindi ganun \\ud83d\\ude0aKung ilan yung absent or paexcuse nyo kailangan nyo sya palitan (magcommunity service)\\n\\n\\u2705Attendance ay 60\\u0025 ng grade nyo sa CWTS, kaya malaki ang impact kapag hindi nyo napalitan yung absent or excuse nyo.\\n\\n\\u2705Every meeting required magdala ng sariling walis tingting, walang dalang walis equivalent to 1 late\\n\\n\\u2705Every meeting required isuot ang NSTP shirt, hindi nakauniform equivalent to 1 late. \\n\\n\\u27054 hours tayo every meeting , kapag 8am tayo pumasok ibig sabihin hanggang 12noon tayo, kaya wala magtatanong kung uwian na ba etc, maswerte nalang tayo kung papauwiin tayo agad \\ud83e\\udd70\\n\\nSana malinaw \\ud83d\\ude0a\\n\\nThank you\",[9],[19,\"80\"],[19,\"1379820553630715\"],[19,\"0\"],[19,\"1767964058415\"],[19,\"1767964058415\"],[9],\"mid.$gAATm8IHz8_uh1CPrL2bot6hxseQ2\",\"7415378720555394102\",[19,\"100000925749366\"],[9],false,[19,\"0\"],[19,\"0\"],[19,\"2\"],[19,\"2\"],false,[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],[9],false,[9],false,[9],[9],[9],[19,\"3\"],false,[19,\"0\"],[19,\"1\"],[9],[9],[19,\"0\"],[9],\"{}\",[9],[9],[9],[9],[9],[9],false,[9],[9],\"{\\\"ai_metadata\\\":{\\\"is_ai_generated\\\":true}}\",[19,\"0\"],[9],[9],[9],[9],[19,\"0\"],[9],[9],[9],[9],[9],[9],[9]]],[1,[3,1,[19,\"4449569714558976734\"]],[3,2,[19,\"5052393096034214913\"]],[3,3,[19,\"108110616687807490\"]],[3,4,[19,\"36028801322319892\"]],[3,5,[19,\"603632722363156612\"]],[3,6,[19,\"0\"]],[5,\"writeThreadCapabilities\",[19,\"1379820553630715\"],[2,1],[2,2],[2,3],[2,4],[2,5]]],[1,[5,\"deleteMessageRequest\",[19,\"1379820553630715\"]]],[1,[5,\"deleteThenInsertThread\",[19,\"1778677534145\"],[19,\"1778677534145\"],\"\\u5988\\u5988\\\/Mader: Ot baligtad ya ing sumbrero na\",\"Ayeras fam! \\u2764\\ufe0f\",\"https:\\\/\\\/scontent.fcrk4-1.fna.fbcdn.net\\\/v\\\/t1.15752-9\\\/638839241_763212596854733_2631646609228512640_n.jpg?stp=dst-jpg_s100x100_tt6&_nc_cat=106&ccb=1-7&_nc_sid=029a7d&_nc_eui2=AeGKjxjGW6m1inKbyiSe9yCJLCFqxcCBY98sIWrFwIFj3-Lgv68GGJbHnwt8mBRGnOm7lpnu3ZmCWrL2GBhxy5kb&_nc_ohc=-9nu4Ivn1WUQ7kNvwGBi7CM&_nc_oc=Adpm-5HX9ICgukvo8kcxNdFhJClfYfSqCDc1GuEBpwB-WodGJw1GOZiOatY-VGmwhbk&_nc_zt=23&_nc_ht=scontent.fcrk4-1.fna&_nc_ss=7b2a8&oh=03_Q7cD5QF2RCJZAK2bHE149v-46S3lzOSM3-IZSnTFM_gAnS-W-Q&oe=6A2C930A\",false,[19,\"80\"],[19,\"5275915445812633\"],[19,\"0\"],[19,\"2\"],\"inbox\",\"\\\/messaging\\\/lightspeed\\\/media_fa